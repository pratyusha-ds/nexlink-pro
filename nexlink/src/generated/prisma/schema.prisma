generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum for status
enum ApplicationStatus {
  PENDING
  APPLIED
  BEING_PROCESSED
  WAITING_FOR_INTERVIEW
  REJECTED
}

// Enum for type
enum ApplicationType {
  REGULAR
  INTERNSHIP
}

// Enum for mode 
enum WorkMode {
  REMOTE
  ON_SITE
  HYBRID
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  email        String        @unique
  firstName    String?
  middleName   String?
  lastName     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  reminders    Boolean       @default(false)

  @@map("users")
}

model Application {
  id               Int               @id @default(autoincrement())
  userId           String
  companyName      String
  jobTitle         String
  status           ApplicationStatus
  mode             WorkMode
  website          String?
  jobUrl           String?
  description      String
  email            String
  location         String
  type             ApplicationType
  notes            String?
  interviewDnT     DateTime?
  salary           String?
  logoUrl          String?
  enableReminder   Boolean           @default(false)
  reminderInterval Int               @default(3)
  expirationDate   DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  reminders        Reminder[]

  user User @relation(fields: [userId], references: [id])

  @@map("applications")
}

model CachedJob {
  id       String   @id
  title    String
  company  String
  location String
  date     String
  url      String
  logo     String?
  cachedAt DateTime @default(now())

  @@map("cached_jobs")
}

model Reminder {
  id            Int       @id @default(autoincrement())
  applicationId Int       @unique
  lastSentAt    DateTime?
  nextSendAt    DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@map("reminders")
}
